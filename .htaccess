# URLs propres — structure en répertoires
Options +FollowSymLinks -MultiViews
DirectorySlash Off
RewriteEngine On

# Rediriger /page.html et /page/ vers /page (URLs canoniques sans slash ni .html)
RewriteCond %{THE_REQUEST} /([^.]+)\.html [NC]
RewriteRule ^ /%1 [R=301,L]

RewriteRule ^([^/]+)/$ /$1 [R=301,L]
